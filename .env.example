# Runtime
ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=https://your-tunnel.example.com

# LiveKit
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
LIVEKIT_AGENT_NAME=mandi-gemini-agent
LIVEKIT_EXPLICIT_DISPATCH=true
LIVEKIT_ROOM_PREFIX=mandi-call
LIVEKIT_NUM_IDLE_PROCESSES=1

# Gemini Live
GOOGLE_API_KEY=replace-me
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_VOICE=Puck

# Exotel
EXOTEL_ACCOUNT_SID=replace-me
EXOTEL_API_KEY=replace-me
EXOTEL_API_TOKEN=replace-me
EXOTEL_SUBDOMAIN=api.in.exotel.com
EXOTEL_CALLER_ID=replace-me
EXOTEL_AI_CALLER_ID=
EXOTEL_AGENTSTREAM_APP_ID=replace-me
EXOTEL_AGENTSTREAM_FLOW_URL=
EXOTEL_STATUS_CALLBACK_URL=https://your-tunnel.example.com/exotel/status

# Local-only manual testing. Do not commit real customer numbers.
TEST_CALL_TO=
